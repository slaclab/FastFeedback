record(mbbo, "FBCK:$(AREA):$(LOOP):FBCK_TYPE") {
    field(DESC, "Feedback Type (SXR/HXR/Transverse)")
    field(DTYP, "FfConfig")
    field(OUT,  "@FBCK_TYPE")
    field(PINI, "YES")
    field(VAL,  "$(FBCK_TYPE)")
    field(ZRVL, "0")
    field(ONVL, "1")
    field(TWVL, "2")
    field(ZRST, "Long. HXR")
    field(ONST, "Long. SXR")
    field(TWST, "Transverse")
    field(ZRSV,  "NO_ALARM")
    field(ONSV,  "NO_ALARM")
    field(TWSV,  "NO_ALARM")
}
