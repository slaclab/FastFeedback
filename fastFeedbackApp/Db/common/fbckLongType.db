record(bo, "FBCK:$(AREA):$(LOOP):LG_TYPE") {
    field(DESC, "Feedback Type (SXR/HXR/Transverse)")
    field(DTYP, "FfConfig")
    field(OUT,  "@LG_TYPE")
    field(PINI, "YES")
    field(RVAL, "$(LG_TYPE)")
    field(ZNAM, "Long. HXR")
    field(ONAM, "Long. SXR")
    field(ZRSV,  "NO_ALARM")
    field(ONSV,  "NO_ALARM")
# Disable caputs to this record:
    field(DISP, "1")
}

