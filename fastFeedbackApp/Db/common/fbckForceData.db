record(bo, "FBCK:$(AREA):$(LOOP):FORCESTATES"){
    field(DESC, "Toggle forced known state data to FCOM")
    field(DTYP, "FfConfig")
    field(OUT,  "@$(LOOP) FORCESTATE")
    field(PINI, "YES")
    field(ZNAM, "NO")
    field(ONAM, "YES")
    field(VAL,  "$(FDVAL=0)")
    field(ZSV,  "NO_ALARM")
    field(OSV,  "NO_ALARM")
}

record(bo, "FBCK:$(AREA):$(LOOP):FORCEACTUATORS"){
    field(DESC, "Toggle forced known actuator data to FCOM")
    field(DTYP, "FfConfig")
    field(OUT,  "@$(LOOP) FORCEACT")
    field(PINI, "YES")
    field(ZNAM, "NO")
    field(ONAM, "YES")
    field(VAL,  "$(FDVAL=0)")
    field(ZSV,  "NO_ALARM")
    field(OSV,  "NO_ALARM")
}

record(ao, "FBCK:$(AREA):$(LOOP):FORCEDSTATEVALUE"){
    field(DESC, "val to be written to dev states chan")
    field(DTYP, "FfConfig")
    field(OUT,  "@$(LOOP) FORCEDSTATE")
    field(PINI, "YES")
    field(VAL,  "0.0")
}

